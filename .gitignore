# macOS
.DS_Store

# Node dependencies
node_modules/

# Local environment and signing credentials
.env
.env.*
!.env.example
build.json
release-signing.properties
debug-signing.properties
*.keystore
*.jks
*.p12
*.mobileprovision

# Cordova generated dependencies. Keep the local NativeSession plugin source.
/plugins/*
!/plugins/native-session/
!/plugins/native-session/**
platforms/ios/packages/**/Plugins/

# Keep platforms/ tracked because native application code lives there.
# Ignore only native build output and machine-local state.
platforms/**/build/
platforms/**/.gradle/
platforms/**/local.properties
platforms/**/*.apk
platforms/**/*.aab
platforms/**/*.ap_
platforms/android/tools/.gradle/
platforms/android/tools/gradle/
platforms/android/tools/gradlew
platforms/android/tools/gradlew.bat

# Keep native API settings and mock payloads under version control.
!platforms/android/app/src/main/assets/app-settings.json
!platforms/android/app/src/main/assets/mock-responses/
!platforms/android/app/src/main/assets/mock-responses/**
!platforms/ios/App/Resources/AppSettings.json
!platforms/ios/App/Resources/MockResponses/
!platforms/ios/App/Resources/MockResponses/**

# Cordova and mobile build outputs
www/cordova.js
www/cordova_plugins.js
www/plugins/
build/
artifacts/
dist/
coverage/

# Android build artifacts
.gradle/
*.apk
*.aab
*.ap_
*.ipa
local.properties

# iOS build artifacts
DerivedData/
**/.swiftpm/
**/xcuserdata/
*.xcuserstate
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
*.xcarchive
*.dSYM
*.dSYM.zip

# Logs and temporary files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.tmp
*.swp
