# macOS
.DS_Store

# Node dependencies
node_modules/

# Cordova generated dependencies
plugins/

# Keep platforms/ tracked because native application code lives there.
# Ignore only native build output and machine-local state.
platforms/**/build/
platforms/**/.gradle/
platforms/**/local.properties
platforms/**/*.apk
platforms/**/*.aab
platforms/**/*.ap_

# Cordova and mobile build outputs
www/cordova.js
www/cordova_plugins.js
www/plugins/
build/
dist/
coverage/

# Android build artifacts
.gradle/
*.apk
*.aab
*.ap_
local.properties

# iOS build artifacts
DerivedData/
*.xcuserstate
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/

# Logs and temporary files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.tmp
*.swp
